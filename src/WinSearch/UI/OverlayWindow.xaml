<Window x:Class="WinSearch.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:WinSearch.UI.ViewModels"
        Title="WinSearch"
        Width="640"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{DynamicResource OverlayBackground}"
            CornerRadius="12"
            Padding="8"
            Effect="{DynamicResource OverlayShadow}">

        <StackPanel>
            <!-- Search Box -->
            <Grid Margin="8,8,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                           FontSize="18" VerticalAlignment="Center" Margin="8,0,8,0"
                           Foreground="{DynamicResource SearchIconForeground}"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Segoe UI Variable"
                         FontSize="18"
                         Height="48"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource SearchBoxForeground}"
                         CaretBrush="{DynamicResource SearchBoxForeground}"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchBox_KeyDown"/>

                <TextBlock Grid.Column="1" Text="Search settings, apps, files…"
                           FontFamily="Segoe UI Variable" FontSize="18"
                           Foreground="{DynamicResource PlaceholderForeground}"
                           VerticalAlignment="Center" IsHitTestVisible="False"
                           Visibility="{Binding IsQueryEmpty, Converter={StaticResource BoolToVis}}"/>

                <ProgressBar Grid.Column="2" Width="16" Height="16" IsIndeterminate="True"
                             Style="{DynamicResource CircularProgressStyle}"
                             Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"
                             Margin="4,0,8,0"/>
            </Grid>

            <!-- Separator -->
            <Rectangle Height="1" Fill="{DynamicResource SeparatorColor}" Margin="8,0"/>

            <!-- Results List -->
            <ItemsControl x:Name="ResultsList"
                          ItemsSource="{Binding Results}"
                          Margin="8,4,8,8"
                          Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ResultBorder"
                                Background="{DynamicResource ResultBackground}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,2"
                                Cursor="Hand"
                                MouseLeftButtonDown="Result_MouseLeftButtonDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0" Source="{Binding Icon}"
                                       Width="24" Height="24" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{DynamicResource ResultTitleForeground}"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               FontSize="12"
                                               Foreground="{DynamicResource ResultSubtitleForeground}"
                                               Visibility="{Binding HasSubtitle, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <Border Grid.Column="2" Background="{DynamicResource BadgeBackground}"
                                        CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BadgeForeground}"/>
                                </Border>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource ResultSelectedBackground}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Hint bar -->
            <TextBlock Text="↑↓ navigate  ↵ open  Ctrl+↵ admin  Esc dismiss"
                       FontSize="11"
                       Foreground="{DynamicResource HintForeground}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"
                       Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </Border>
</Window>
