<Window x:Class="WinSearch.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinSearch Settings"
        Width="500" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="WinSearch Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Search Scopes -->
            <GroupBox Header="Search Scopes" Padding="10" Margin="0,0,0,12">
                <StackPanel>
                    <CheckBox Content="Windows Settings" IsChecked="{Binding Settings.EnableWindowsSettings}" Margin="0,3"/>
                    <CheckBox Content="Control Panel" IsChecked="{Binding Settings.EnableControlPanel}" Margin="0,3"/>
                    <CheckBox Content="Installed Apps" IsChecked="{Binding Settings.EnableInstalledApps}" Margin="0,3"/>
                    <CheckBox Content="Files (Windows Search)" IsChecked="{Binding Settings.EnableFiles}" Margin="0,3"/>
                    <CheckBox Content="Running Processes" IsChecked="{Binding Settings.EnableProcesses}" Margin="0,3"/>
                    <CheckBox Content="Registry Favourites" IsChecked="{Binding Settings.EnableRegistry}" Margin="0,3"/>
                </StackPanel>
            </GroupBox>

            <!-- General -->
            <GroupBox Header="General" Padding="10">
                <StackPanel>
                    <DockPanel Margin="0,3">
                        <TextBlock Text="Result limit:" VerticalAlignment="Center" Width="120"/>
                        <TextBox Text="{Binding Settings.ResultLimit}" Width="60"/>
                    </DockPanel>
                    <CheckBox Content="Launch WinSearch on startup" IsChecked="{Binding Settings.LaunchOnStartup}" Margin="0,3"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
